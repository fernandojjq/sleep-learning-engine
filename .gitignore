# Local user-supplied assets - never commit media files
# Each user brings their own ambient music; we do not distribute any.

# Local ambient track directories (user puts their own .mp3 here)
assets/ambient/*.mp3
assets/ambient/_originals/
assets/ambient/_normalized/

# Local package fallback (kept for the local CLI workflow)
src/sleep_learning_engine/assets/ambient/*.mp3

# Build artifacts and dist files
build/
dist/
*.egg-info/
*.whl

# Python caches
__pycache__/
*.pyc
*.pyo
.pytest_cache/
.cache/

# Virtual envs
.venv/
venv/

# IDE / OS
.idea/
.vscode/
.DS_Store
Thumbs.db

# User-specific config (TOML may contain personal paths and credentials)
.sleeplens.toml
.sleep_learning_engine.toml
*.local.toml

# Test artifacts
output/
.cache/
*.log
*.tmp

# Cached ffmpeg binaries
cache/ffmpeg.exe
cache/ffprobe.exe

# Loudness audit cache
cache/_loudness_audit.json

# Smoke / test fixture outputs
cache/_*.py
!cache/__init__.py
