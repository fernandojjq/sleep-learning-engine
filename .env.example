# Sleeplens - Sleep learning video studio

# ============================================================================
# Default out-of-the-box experience: NVIDIA NIM free tier with DeepSeek V4.
# Sign up at https://build.nvidia.com to get a key (no credit card needed).
# ============================================================================
SLEEPLENS_API_KEY=
SLEEPLENS_BASE_URL=https://integrate.api.nvidia.com/v1
SLEEPLENS_MODEL=deepseek-ai/deepseek-v4

# Optional: override the bundled ffmpeg path if you already have it on PATH.
# FFMPEG_BIN=C:\path\to\ffmpeg.exe
# FFPROBE_BIN=C:\path\to\ffprobe.exe

# Optional: override the project root (defaults to the repo checkout).
# SLEEPLENS_HOME=D:\proyectos\Proyectos Github\sleeplens
